# Database
POSTGRES_PASSWORD=change_me_strong_password

# API
JWT_SECRET=change_me_very_long_random_string_at_least_32_chars
PORT=4000
NODE_ENV=production

# Caddy host — use :80 for HTTP-only (IP access), or your domain for auto-HTTPS
# Examples:
#   :80                     → http://IP (no HTTPS)
#   novel.example.com       → https://novel.example.com (auto HTTPS via Let's Encrypt)
CADDY_HOST=:80

# Optional scraper settings
WORKER_CONCURRENCY=2
SCRAPER_USER_AGENT=
SCRAPER_COOKIES_EMPIRENOVEL_COM=
