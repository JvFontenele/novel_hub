{
  "name": "@novel-hub/worker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file=../../.env src/main.ts",
    "build": "tsc",
    "start": "node dist/main.js",
    "retry:failed": "tsx --env-file=../../.env src/scripts/retry-failed-jobs.ts",
    "retry:failed:all": "tsx --env-file=../../.env src/scripts/retry-failed-jobs.ts all"
  },
  "dependencies": {
    "@novel-hub/scraping": "workspace:*",
    "@novel-hub/shared": "workspace:*",
    "bullmq": "^5.0.0",
    "postgres": "^3.4.3",
    "undici": "^6.0.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0"
  }
}
